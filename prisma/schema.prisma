generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Owner {
  id        String    @id @default(cuid())
  name      String
  role      String?
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ProductUnit {
  id        String            @id @default(cuid())
  name      String            @unique
  symbol    String?
  isActive  Boolean           @default(true)
  products  Product[]
  saleUnits ProductSaleUnit[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Product {
  id         String   @id @default(cuid())
  name       String
  ownerId    String
  categoryId String
  unitId     String
  stock      Int      @default(0)
  lowStock   Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner     Owner             @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  category  Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  unit      ProductUnit       @relation(fields: [unitId], references: [id], onDelete: Restrict)
  saleUnits ProductSaleUnit[]
  saleItems SaleItem[]
  stockMovements StockMovement[]

  @@index([ownerId])
  @@index([categoryId])
  @@index([unitId])
}


model ProductSaleUnitPriceRule {
  id                String          @id @default(cuid())
  productSaleUnitId String
  quantity          Int
  price             Decimal         @db.Decimal(12, 2)
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  productSaleUnit   ProductSaleUnit @relation(fields: [productSaleUnitId], references: [id], onDelete: Cascade)

  @@index([productSaleUnitId])
  @@unique([productSaleUnitId, quantity])
}

model ProductSaleUnit {
  id                 String   @id @default(cuid())
  productId          String
  unitId             String
  quantityInBaseUnit Int
  sellingPrice       Decimal  @db.Decimal(12, 2)
  isDefault          Boolean  @default(false)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  unit      ProductUnit @relation(fields: [unitId], references: [id], onDelete: Restrict)
  saleItems SaleItem[]
  priceRules ProductSaleUnitPriceRule[]

  @@index([productId])
  @@index([unitId])
}

enum PaymentStatus {
  paid
  partial
  owed
}

model Sale {
  id            String        @id @default(cuid())
  customerName  String?
  subtotal      Decimal       @db.Decimal(12, 2)
  amountPaid    Decimal       @db.Decimal(12, 2)
  balance       Decimal       @db.Decimal(12, 2)
  paymentStatus PaymentStatus
  items         SaleItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SaleItem {
  id                String   @id @default(cuid())
  saleId            String
  productId         String
  productSaleUnitId String
  quantity          Int
  unitPrice         Decimal  @db.Decimal(12, 2)
  total             Decimal  @db.Decimal(12, 2)
  baseUnitsConsumed Int
  createdAt         DateTime @default(now())

  sale            Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  productSaleUnit ProductSaleUnit @relation(fields: [productSaleUnitId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
  @@index([productSaleUnitId])
}
enum DebtTransactionType {
  sale
  payment
  adjustment
}

model CustomerDebt {
  id           String   @id @default(cuid())
  customerName String   @unique
  totalDebt    Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions DebtTransaction[]
}

model DebtTransaction {
  id             String              @id @default(cuid())
  customerDebtId String
  type           DebtTransactionType
  amount         Decimal             @db.Decimal(12, 2)
  note           String?
  createdAt      DateTime            @default(now())

  customerDebt   CustomerDebt        @relation(fields: [customerDebtId], references: [id], onDelete: Cascade)

  @@index([customerDebtId])
}
enum StockMovementType {
  restock
  sale
  adjustment
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  type        StockMovementType
  quantity    Int
  note        String?
  createdAt   DateTime          @default(now())

  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}


