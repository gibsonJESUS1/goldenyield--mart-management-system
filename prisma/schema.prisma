generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Owner {
  id        String    @id @default(cuid())
  name      String
  role      String?
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ProductUnit {
  id        String            @id @default(cuid())
  name      String            @unique
  symbol    String?
  isActive  Boolean           @default(true)
  products  Product[]
  saleUnits ProductSaleUnit[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Product {
  id               String   @id @default(cuid())
  name             String
  ownerId          String
  categoryId       String
  unitId           String
  stock            Int      @default(0)
  lowStock         Int      @default(0)
  active           Boolean  @default(true)
  currentCostPrice Decimal? @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner               Owner                    @relation(fields: [ownerId], references: [id])
  category            Category                 @relation(fields: [categoryId], references: [id])
  unit                ProductUnit              @relation(fields: [unitId], references: [id])
  saleUnits           ProductSaleUnit[]
  saleItems           SaleItem[]
  stockMovements      StockMovement[]
  purchaseItems       PurchaseItem[]
  costPriceHistories  ProductCostPriceHistory[]
}

model ProductSaleUnitPriceRule {
  id                String   @id @default(cuid())
  productSaleUnitId String
  quantity          Int
  price             Decimal  @db.Decimal(12, 2)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  productSaleUnit ProductSaleUnit @relation(fields: [productSaleUnitId], references: [id], onDelete: Cascade)

  @@unique([productSaleUnitId, quantity])
  @@index([productSaleUnitId])
}

model ProductSaleUnit {
  id                 String   @id @default(cuid())
  productId          String
  unitId             String
  quantityInBaseUnit Int
  sellingPrice       Decimal  @db.Decimal(12, 2)
  isDefault          Boolean  @default(false)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product    Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  unit       ProductUnit                @relation(fields: [unitId], references: [id], onDelete: Restrict)
  saleItems  SaleItem[]
  priceRules ProductSaleUnitPriceRule[]

  @@index([productId])
  @@index([unitId])
}

enum PaymentStatus {
  paid
  partial
  owed
}

model Sale {
  id           String   @id @default(cuid())
  customerName String?
  subtotal     Decimal  @db.Decimal(12, 2)
  amountPaid   Decimal  @db.Decimal(12, 2)
  balance      Decimal  @db.Decimal(12, 2)
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items            SaleItem[]
  debtTransactions DebtTransaction[]
}

model SaleItem {
  id                 String   @id @default(cuid())
  saleId             String
  productId          String
  saleUnitId         String?
  quantity           Int
  quantityInBaseUnit Int
  unitPrice          Decimal  @db.Decimal(12, 2)
  lineTotal          Decimal  @db.Decimal(12, 2)
  unitCostPrice      Decimal? @db.Decimal(12, 2)
  lineCostTotal      Decimal? @db.Decimal(12, 2)
  lineProfit         Decimal? @db.Decimal(12, 2)
  createdAt          DateTime @default(now())

  sale     Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product  Product          @relation(fields: [productId], references: [id])
  saleUnit ProductSaleUnit? @relation(fields: [saleUnitId], references: [id])

  @@index([saleId])
  @@index([productId])
}

enum DebtTransactionType {
  SALE_DEBT
  MANUAL_DEBT
  PAYMENT
  ADJUSTMENT_INCREASE
  ADJUSTMENT_DECREASE
}

model CustomerDebt {
  id           String   @id @default(cuid())
  customerName String
  phone        String?
  note         String?
  balance      Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions DebtTransaction[]
}

model DebtTransaction {
  id             String              @id @default(cuid())
  customerDebtId String
  saleId         String?
  type           DebtTransactionType
  amount         Decimal             @db.Decimal(12, 2)
  description    String?
  reference      String?
  createdAt      DateTime            @default(now())

  customerDebt CustomerDebt @relation(fields: [customerDebtId], references: [id], onDelete: Cascade)
  sale         Sale?        @relation(fields: [saleId], references: [id])

  @@index([customerDebtId])
  @@index([saleId])
  @@index([createdAt])
}

enum StockMovementType {
  IN
  OUT
}

model StockMovement {
  id        String            @id @default(cuid())
  productId String
  type      StockMovementType
  quantity  Int
  note      String?
  createdAt DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Purchase {
  id           String   @id @default(cuid())
  reference    String?
  supplierName String?
  note         String?
  totalAmount  Decimal  @db.Decimal(12, 2)
  purchasedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items PurchaseItem[]
}

model PurchaseItem {
  id                 String   @id @default(cuid())
  purchaseId         String
  productId          String
  quantityInBaseUnit Int
  unitCostPrice      Decimal  @db.Decimal(12, 2)
  lineTotal          Decimal  @db.Decimal(12, 2)
  createdAt          DateTime @default(now())

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
}

enum CostPriceChangeType {
  PURCHASE
  MANUAL_UPDATE
}

model ProductCostPriceHistory {
  id           String              @id @default(cuid())
  productId    String
  oldCostPrice Decimal?            @db.Decimal(12, 2)
  newCostPrice Decimal             @db.Decimal(12, 2)
  changeType   CostPriceChangeType
  note         String?
  reference    String?
  createdAt    DateTime            @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([changeType])
  @@index([createdAt])
}